---
const { title, description } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />

    <title>{title}</title>

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600&family=Source+Sans+3:wght@300;350;400;450;550;600&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/png" href="/logo-color.png" />

    <style>
      /* critical above-fold styles — prevents FOUC */
      body { visibility: visible; }
      html { visibility: visible; }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
