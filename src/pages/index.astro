---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const phone = '(16) 98999-1790';
const phoneLink = '+5516989991790';
const instagram = '@Chrismoyses';
const address = 'Av. José Espírito Santo Tanajura, 14 - Centro, Miguelópolis - SP';
const googleMapsUrl = 'https://maps.google.com/?q=Av.+José+Espírito+Santo+Tanajura,+14+-+Centro,+Miguelópolis+-+SP';
const whatsappUrl = `https://wa.me/${phoneLink}`;

const services = [
  'Cardiologia Geral',
  'Arritmias',
  'Cardiologia Geriátrica',
  'Cardiopatias',
  'Eletrocardiograma',
  'Hipertensão Arterial',
  'Insuficiência Cardíaca / Angina',
  'Dislipidemias',
  'Infarto do Miocárdio',
  'Holter 24h',
  'MAPA 24h',
  'Coronariopatias',
];
---

<Layout
  title="Dra. Christiane Moysés — Cardiologia e Clínica Médica | Miguelópolis-SP"
  description="Dra. Christiane Moysés — Cardiologia e Clínica Médica em Miguelópolis-SP. CRM 141228. Agende sua consulta."
>
  <!-- HEADER -->
  <header class="site-header">
    <div class="container">
      <a href="#hero" class="header-brand">
        <object data="/pulse.svg" type="image/svg+xml" class="nav-pulse" aria-hidden="true" tabindex="-1"></object>
        <span class="nav-name">Christiane Moysés</span>
        <span class="nav-stroke" aria-hidden="true"></span>
        <span class="nav-specialty">CARDIOLOGIA</span>
      </a>
    </div>
  </header>

  <main>
    <!-- HERO -->
    <section id="hero" class="hero">
      <div class="container">
        <div class="hero-inner">
          <div class="hero-text">
            <svg class="hero-ecg" viewBox="0 0 322 247" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
              <g transform="matrix(1,0,0,1,159.445,117.001)">
                <path class="ecg-anim" stroke-linejoin="round" stroke-linecap="round" stroke-width="3" stroke="#C2181C"
                  d="M-97.667,9.888C-97.667,9.888,-58.556,9.888,-58.556,9.888C-58.556,9.888,-51.889,0.999,-51.889,0.999C-51.889,0.999,-43.667,41.445,-43.667,41.445C-43.667,41.445,-31.222,-41.445,-31.222,-41.445C-31.222,-41.445,-23,8.333,-23,8.333C-23,8.333,-14.556,-7.889,-14.556,-7.889C-14.556,-7.889,-7,9.445,-7,9.445C-7,9.445,27.889,9.888,27.889,9.888C27.889,9.888,35.889,-24.335,35.889,-24.335C35.889,-24.335,45.889,19.221,45.889,19.221C45.889,19.221,54.556,-0.112,54.556,-0.112C54.556,-0.112,61.222,9.221,61.222,9.221C61.222,9.221,80.216,9.466,95.397,9.663" />
              </g>
            </svg>
            <h1 class="hero-name">Dra. Christiane<br />Moysés</h1>
            <p class="hero-specialty">Cardiologia e Clínica Médica</p>

            <div class="hero-meta">
              <span class="hero-badge">CRM 141228</span>
              <span class="hero-badge">Miguelópolis-SP</span>
            </div>
          </div>

          <div class="hero-visual" aria-hidden="true">
            <img src="/cardio- (1).png" alt="" class="hero-visual-img" width="600" height="600" />
          </div>
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section id="servicos" class="section-dark">
      <div class="container">
        <div class="split-panel split-reverse">
          <div class="split-media">
            <img src="/atuacao.jpg" alt="Áreas de atuação" width="800" height="600" loading="lazy" />
          </div>
          <div class="split-text">
            <h2>Áreas de atuação</h2>
            <p style="color:var(--color-dark-muted);margin-bottom:var(--space-lg)">Atendimento em cardiologia e clínica médica geral para toda a família.</p>

            <div class="services-grid">
              {services.map((service) => (
                <div class="service-item">
                  <svg class="service-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
                  <span>{service}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section id="sobre" class="section-cream">
      <div class="container">
        <div class="split-panel">
          <div class="split-text">
            <h2 style="margin-bottom:var(--space-md)">Sobre a Dra. Christiane</h2>

            <div class="about-placeholder">
              <span class="about-placeholder-badge">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                A confirmar com a cliente
              </span>
              <p>Formação acadêmica, tempo de atuação e abordagem com pacientes em validação.</p>
              <p>As informações desta seção serão atualizadas após confirmação direta com a Dra. Christiane Moysés.</p>
            </div>
          </div>
          <div class="split-media">
            <img src="/foto-dra.png" alt="Dra. Christiane Moysés" width="500" height="500" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- REVIEWS -->
    <section id="avaliacoes">
      <div class="container">
        <div class="reviews-header">
          <h2>O que dizem os pacientes</h2>
          <svg class="reviews-ecg-divider" viewBox="0 0 180 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M0 20 L30 20 L42 20 L50 4 L60 36 L68 20 L85 20 L180 20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>

        <div class="reviews-card">
          <span class="reviews-score">5.0</span>
          <span class="reviews-count">26 avaliações no Google</span>
          <blockquote class="reviews-quote">Excelente profissional, muito atenciosa e competente</blockquote>
          <span class="reviews-source">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Avaliação no Google
          </span>
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contato" class="section-dark">
      <div class="container">
        <h2>Entre em contato</h2>

        <div class="contact-grid" style="margin-top:var(--space-xl)">
          <a href={`tel:${phoneLink}`} class="contact-item" aria-label={`Telefone: ${phone}`}>
            <svg class="contact-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <div>
              <div class="contact-label">Telefone</div>
              <div class="contact-value">{phone}</div>
            </div>
          </a>

          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="contact-item" aria-label={`WhatsApp: ${phone}`}>
            <svg class="contact-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <div>
              <div class="contact-label">WhatsApp</div>
              <div class="contact-value">{phone}</div>
            </div>
          </a>

          <a href={googleMapsUrl} target="_blank" rel="noopener noreferrer" class="contact-item" aria-label="Endereço no Google Maps">
            <svg class="contact-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <div>
              <div class="contact-label">Endereço</div>
              <div class="contact-value">{address}</div>
            </div>
          </a>

          <a href={`https://instagram.com/${instagram.replace('@', '')}`} target="_blank" rel="noopener noreferrer" class="contact-item" aria-label={`Instagram ${instagram}`}>
            <svg class="contact-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            <div>
              <div class="contact-label">Instagram</div>
              <div class="contact-value">{instagram}</div>
            </div>
          </a>
        </div>
      </div>
    </section>
  </main>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="container">
      <p class="footer-text">Dra. Christiane Moysés · CRM 141228</p>
      <p class="footer-text">Cardiologia e Clínica Médica · Miguelópolis-SP</p>
      <a href={`https://instagram.com/${instagram.replace('@', '')}`} class="footer-instagram" target="_blank" rel="noopener noreferrer">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        {instagram}
      </a>
    </div>
  </footer>

  <!-- DOCK mobile-only -->
  <div class="bottom-dock" role="toolbar" aria-label="Contato rápido">
    <a href={whatsappUrl} class="dock-btn dock-whatsapp" target="_blank" rel="noopener noreferrer">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      <span>WhatsApp</span>
    </a>
    <a href={`tel:${phoneLink}`} class="dock-btn dock-phone">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      <span>Ligar</span>
    </a>
  </div>
</Layout>
