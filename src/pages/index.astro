---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const phone = '(16) 98999-1790';
const phoneLink = '+5516989991790';
const instagram = '@Chrismoyses';
const address = 'Av. José Espírito Santo Tanajura, 14 - Centro, Miguelópolis - SP';
const googleMapsUrl = 'https://maps.google.com/?q=Av.+José+Espírito+Santo+Tanajura,+14+-+Centro,+Miguelópolis+-+SP';
const whatsappUrl = `https://wa.me/${phoneLink}`;

const serviceGroups = [
  {
    label: 'Consultas e acompanhamento',
    items: ['Cardiologia Geral', 'Cardiologia Geriátrica', 'Hipertensão Arterial', 'Dislipidemias'],
  },
  {
    label: 'Condições cardíacas',
    items: ['Arritmias', 'Cardiopatias', 'Insuficiência Cardíaca / Angina', 'Infarto do Miocárdio', 'Coronariopatias'],
  },
  {
    label: 'Exames',
    items: ['Eletrocardiograma', 'Holter 24h', 'MAPA 24h'],
  },
];
---

<Layout
  title="Dra. Christiane Moysés &mdash; Cardiologia e Clínica Médica"
  description="Dra. Christiane Moysés — Cardiologia e Clínica Médica em Miguelópolis-SP. CRM 141228. Agende sua consulta pelo WhatsApp."
>
  <!-- HEADER -->
  <header class="site-header">
    <div class="container">
      <a href="#hero" aria-label="Dra. Christiane Moysés — Início">
        <img
          src="/logo-color.png"
          alt=""
          class="header-logo"
          width="180"
          height="32"
        />
      </a>
      <a href={whatsappUrl} class="btn btn-whatsapp header-cta" target="_blank" rel="noopener noreferrer">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/><path d="M16 10a1 1 0 0 0-2 0 2.5 2.5 0 0 1-1.5 2.3"/><path d="M17 10a5 5 0 0 0-5-5"/></svg>
        WhatsApp
      </a>
    </div>
  </header>

  <main>
    <!-- HERO -->
    <section id="hero" class="hero">
      <div class="container">
        <img
          src="/logo-color.png"
          alt=""
          class="hero-logo"
          width="280"
          height="72"
        />
        <h1 class="hero-name">Dra. Christiane<br />Moysés</h1>
        <p class="hero-specialty">Cardiologia e Clínica Médica</p>

        <div class="hero-meta">
          <span class="hero-badge">CRM 141228</span>
          <span class="hero-rating" aria-label="Avaliação 5 de 5 estrelas no Google, 26 avaliações">
            <span class="hero-stars" aria-hidden="true">★★★★★</span>
            <span class="hero-rating-text">5.0 · 26 avaliações</span>
          </span>
        </div>

        <div class="hero-actions">
          <a href={whatsappUrl} class="btn btn-whatsapp hero-cta" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/><path d="M16 10a1 1 0 0 0-2 0 2.5 2.5 0 0 1-1.5 2.3"/><path d="M17 10a5 5 0 0 0-5-5"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${phoneLink}`} class="btn btn-outline hero-cta-secondary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {phone}
          </a>
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section id="servicos" class="services">
      <div class="container">
        <div class="services-header">
          <h2>Áreas de atuação</h2>
          <p>Atendimento em cardiologia e clínica médica geral para toda a família.</p>
        </div>

        <div class="services-groups">
          {serviceGroups.map((group) => (
            <div class="services-group">
              <h3 class="services-group-label">{group.label}</h3>
              <div class="services-group-items">
                {group.items.map((service) => (
                  <div class="service-item">
                    <svg class="service-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
                    <span class="service-name">{service}</span>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ABOUT (placeholder) -->
    <section id="sobre" class="about">
      <div class="container">
        <img
          src="/logo-white.png"
          alt=""
          class="about-logo"
          width="200"
          height="36"
        />
        <h2>Sobre a Dra. Christiane</h2>

        <div class="about-placeholder">
          <span class="about-placeholder-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            A confirmar com a cliente
          </span>
          <p>Formação acadêmica, tempo de atuação e abordagem com pacientes em validação.</p>
          <p>As informações desta seção serão atualizadas após confirmação direta com a Dra. Christiane Moysés.</p>
        </div>

        <!-- Equipment image -->
        <div class="about-image-wrap">
          <img
            src="/cardio-3.jpg"
            alt="Modelo anatômico de coração humano em consultório médico"
            width="800"
            height="533"
            loading="lazy"
          />
        </div>
      </div>
    </section>

    <!-- REVIEWS -->
    <section id="avaliacoes" class="reviews">
      <div class="container">
        <h2 style="margin-bottom: var(--space-xl)">O que dizem os pacientes</h2>

        <div class="reviews-card">
          <span class="reviews-stars" aria-hidden="true">★★★★★</span>
          <span class="reviews-score">5.0</span>
          <span class="reviews-count">26 avaliações no Google</span>

          <blockquote class="reviews-quote">
            Excelente profissional, muito atenciosa e competente
          </blockquote>

          <span class="reviews-source">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Avaliação no Google
          </span>
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contato" class="contact">
      <div class="container">
        <h2>Entre em contato</h2>

        <div class="contact-grid">
          <!-- Phone -->
          <a href={`tel:${phoneLink}`} class="contact-item" aria-label="Telefone: (16) 98999-1790">
            <svg class="contact-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <div>
              <div class="contact-label">Telefone</div>
              <div class="contact-value">{phone}</div>
            </div>
          </a>

          <!-- WhatsApp -->
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="contact-item" aria-label="WhatsApp: (16) 98999-1790">
            <svg class="contact-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/><path d="M16 10a1 1 0 0 0-2 0 2.5 2.5 0 0 1-1.5 2.3"/><path d="M17 10a5 5 0 0 0-5-5"/></svg>
            <div>
              <div class="contact-label">WhatsApp</div>
              <div class="contact-value">{phone}</div>
            </div>
          </a>

          <!-- Address -->
          <a href={googleMapsUrl} target="_blank" rel="noopener noreferrer" class="contact-item" aria-label="Endereço no Google Maps">
            <svg class="contact-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <div>
              <div class="contact-label">Endereço</div>
              <div class="contact-value">{address}</div>
            </div>
          </a>

          <!-- Instagram -->
          <a href={`https://instagram.com/${instagram.replace('@', '')}`} target="_blank" rel="noopener noreferrer" class="contact-item" aria-label="Instagram @Chrismoyses">
            <svg class="contact-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            <div>
              <div class="contact-label">Instagram</div>
              <div class="contact-value">{instagram}</div>
            </div>
          </a>
        </div>

        <div class="contact-cta">
          <a href={whatsappUrl} class="btn btn-whatsapp" target="_blank" rel="noopener noreferrer" style="font-size: var(--text-base);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/><path d="M16 10a1 1 0 0 0-2 0 2.5 2.5 0 0 1-1.5 2.3"/><path d="M17 10a5 5 0 0 0-5-5"/></svg>
            Agendar consulta pelo WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="container">
      <img
        src="/logo-color.png"
        alt=""
        class="footer-logo"
        width="140"
        height="24"
        loading="lazy"
      />
      <p class="footer-text">Dra. Christiane Moysés · CRM 141228</p>
      <p class="footer-text">Cardiologia e Clínica Médica · Miguelópolis-SP</p>
      <a href={`https://instagram.com/${instagram.replace('@', '')}`} class="footer-instagram" target="_blank" rel="noopener noreferrer">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        {instagram}
      </a>
    </div>
  </footer>

  <!-- FIXED WHATSAPP CTA -->
  <a
    href={whatsappUrl}
    class="fixed-cta"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Agendar consulta pelo WhatsApp"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/><path d="M16 10a1 1 0 0 0-2 0 2.5 2.5 0 0 1-1.5 2.3"/><path d="M17 10a5 5 0 0 0-5-5"/></svg>
    <span class="fixed-cta-text">WhatsApp</span>
  </a>
</Layout>
